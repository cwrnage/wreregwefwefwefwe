--[[
	UILibrary.lua

	A clean, component-based rewrite of the raw Instance.new dump.
	Same visual language (dark background, red accent, tahoma-xp font,
	1px strokes + subtle gradients) but built as reusable factories
	instead of one-off instances, so adding a new toggle/slider/etc.
	is one function call instead of 20+ lines of boilerplate.

	Usage:
		local UI = require(script.UILibrary)
		local Window = UI:CreateWindow({ Title = "serial.xyz" })

		local Tab1 = Window:CreateTab("Aimbot")
		local Left = Tab1:CreateGroupbox("Left", "example section 1")

		Left:AddToggle("MyToggle", { Text = "example toggle", Default = false }, function(state)
			print("toggle ->", state)
		end)

		Left:AddSlider("MySlider", { Text = "example slider", Min = 0, Max = 100, Default = 82, Suffix = "%" }, function(value)
			print("slider ->", value)
		end)
]]

