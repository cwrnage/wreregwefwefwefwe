--[[
	UILibrary.lua

	A clean, component-based rewrite of the raw Instance.new dump.
	Same visual language (dark background, red accent, tahoma-xp font,
	1px strokes + subtle gradients) but built as reusable factories
	instead of one-off instances, so adding a new toggle/slider/etc.
	is one function call instead of 20+ lines of boilerplate.

	Usage:
		local UI = require(script.UILibrary)
		local Window = UI:CreateWindow({ Title = "serial.xyz" })

		local Tab1 = Window:CreateTab("Aimbot")
		local Left = Tab1:CreateGroupbox("Left", "example section 1")

		Left:AddToggle("MyToggle", { Text = "example toggle", Default = false }, function(state)
			print("toggle ->", state)
		end)

		Left:AddSlider("MySlider", { Text = "example slider", Min = 0, Max = 100, Default = 82, Suffix = "%" }, function(value)
			print("slider ->", value)
		end)
]]

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer

--============================================================
-- THEME
--============================================================

local Theme = {
	Background   = Color3.fromRGB(28, 28, 28),
	Section      = Color3.fromRGB(43, 43, 43),
	TitleBar     = Color3.fromRGB(51, 51, 51),
	Accent       = Color3.fromRGB(255, 83, 86),
	StrokeDark   = Color3.fromRGB(51, 51, 51),
	StrokeLight  = Color3.fromRGB(255, 255, 255),
	Text         = Color3.fromRGB(255, 255, 255),
	SubText      = Color3.fromRGB(209, 209, 209),
	MutedText    = Color3.fromRGB(131, 131, 131),
	Font         = Font.new("rbxasset://fonts/families/windows-xp-tahoma.json"),
}

--============================================================
-- LOW LEVEL HELPERS
--============================================================

-- Instance.new + property table + children, in one call.
local function New(className, props, children)
	local inst = Instance.new(className)
	for prop, value in pairs(props or {}) do
		inst[prop] = value
	end
	for _, child in ipairs(children or {}) do
		child.Parent = inst
	end
	return inst
end

-- Adds the "bright top-left, dark bottom-right" bevel look used everywhere
-- in the original dump (outer 1px black stroke + inner light/dark stroke
-- with a subtle vertical gradient).
local function AddBevel(parent, innerColor)
	New("UIStroke", { Parent = parent, ApplyStrokeMode = Enum.ApplyStrokeMode.Border })
	local inner = New("UIStroke", {
		Parent = parent,
		Color = innerColor or Theme.StrokeDark,
		ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
		BorderStrokePosition = Enum.BorderStrokePosition.Inner,
	})
	New("UIGradient", {
		Parent = inner,
		Rotation = 90,
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(159, 159, 159)),
			ColorSequenceKeypoint.new(0.05, Color3.fromRGB(241, 241, 241)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255)),
		}),
	})
end

local function AddFillGradient(parent)
	New("UIGradient", {
		Parent = parent,
		Rotation = 90,
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(173, 173, 173)),
		}),
	})
end

local function Label(props)
	return New("TextLabel", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		FontFace = Theme.Font,
		TextSize = 12,
		TextColor3 = Theme.Text,
		TextStrokeTransparency = 0.5,
		TextXAlignment = Enum.TextXAlignment.Left,
		RichText = true,
		Text = "",
	}, nil), props and (function(l)
		for k, v in pairs(props) do l[k] = v end
		return l
	end)
end

-- simpler helper: creates a TextLabel with props merged in directly
local function TextLabel(props)
	local base = {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		FontFace = Theme.Font,
		TextSize = 12,
		TextColor3 = Theme.Text,
		TextStrokeTransparency = 0.5,
		TextXAlignment = Enum.TextXAlignment.Left,
		RichText = true,
	}
	for k, v in pairs(props or {}) do base[k] = v end
	return New("TextLabel", base)
end

local function Clickable(parent, callback)
	local button = New("TextButton", {
		Parent = parent,
		BackgroundTransparency = 1,
		Text = "",
		Size = UDim2.fromScale(1, 1),
		ZIndex = 10,
	})
	button.MouseButton1Click:Connect(function()
		if callback then callback() end
	end)
	return button
end

-- True on touch-only devices (phones/tablets), false on PC/console with a mouse.
local IsMobile = UserInputService.TouchEnabled and not UserInputService.MouseEnabled

local function IsPressInput(inputType)
	return inputType == Enum.UserInputType.MouseButton1 or inputType == Enum.UserInputType.Touch
end

local function IsMoveInput(inputType)
	return inputType == Enum.UserInputType.MouseMovement or inputType == Enum.UserInputType.Touch
end

local function PointInside(frame, pos)
	local abs, size = frame.AbsolutePosition, frame.AbsoluteSize
	return pos.X >= abs.X and pos.X <= abs.X + size.X and pos.Y >= abs.Y and pos.Y <= abs.Y + size.Y
end

-- Makes `target` draggable by pressing/holding on `handle`. Works with both
-- mouse (PC) and touch (mobile) input.
local function MakeDraggable(handle, target)
	local dragging = false
	local dragStart, startPos

	handle.InputBegan:Connect(function(input)
		if not IsPressInput(input.UserInputType) then return end
		dragging = true
		dragStart = input.Position
		startPos = target.Position

		local conn
		conn = input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
				conn:Disconnect()
			end
		end)
	end)

	UserInputService.InputChanged:Connect(function(input)
		if not dragging or not IsMoveInput(input.UserInputType) then return end
		local delta = input.Position - dragStart
		target.Position = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y
		)
	end)
end

