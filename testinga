-- Toggle -------------------------------------------------------
function Groupbox:AddToggle(flagName, opts, callback)
	opts = opts or {}
	local state = opts.Default or false

	local row = New("Frame", {
		Parent = self.Contents,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 12),
	})

	local box = New("Frame", {
		Parent = row,
		BackgroundColor3 = state and Theme.Accent or Theme.TitleBar,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(12, 12),
	})
	AddFillGradient(box)
	AddBevel(box, state and Theme.Accent or Theme.TitleBar)

	TextLabel({
		Parent = box,
		Position = UDim2.new(1, 6, 0, 0),
		Size = UDim2.fromOffset(115, 12),
		Text = opts.Text or flagName,
	})

	local function setState(newState, fire)
		state = newState
		box.BackgroundColor3 = state and Theme.Accent or Theme.TitleBar
		self.Library.Flags[flagName] = state
		if fire ~= false and callback then callback(state) end
	end

	Clickable(box, function()
		setState(not state)
	end)

	self.Library.Flags[flagName] = state

	return {
		Set = function(_, v) setState(v) end,
		Get = function() return state end,
	}
end

-- Slider -------------------------------------------------------
function Groupbox:AddSlider(flagName, opts, callback)
	opts = opts or {}
	local min = opts.Min or 0
	local max = opts.Max or 100
	local value = math.clamp(opts.Default or min, min, max)
	local suffix = opts.Suffix or ""

	local row = New("Frame", {
		Parent = self.Contents,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 25),
	})
	TextLabel({ Parent = row, Size = UDim2.fromOffset(90, 17), Text = opts.Text or flagName })
	local valueLabel = TextLabel({
		Parent = row,
		Size = UDim2.fromOffset(45, 17),
		Position = UDim2.new(1, -45, 0, 0),
		TextXAlignment = Enum.TextXAlignment.Right,
		TextColor3 = Theme.SubText,
		Text = tostring(value) .. suffix,
	})

	local track = New("Frame", {
		Parent = row,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 7),
		Position = UDim2.new(0, 0, 1, -7),
	})
	AddBevel(track)
	AddFillGradient(track)

	local fill = New("Frame", {
		Parent = track,
		BackgroundColor3 = Theme.Accent,
		BorderSizePixel = 0,
		Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
	})
	AddFillGradient(fill)

	local function setValue(v, fire)
		value = math.clamp(math.floor(v + 0.5), min, max)
		fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
		valueLabel.Text = tostring(value) .. suffix
		self.Library.Flags[flagName] = value
		if fire ~= false and callback then callback(value) end
	end

	local dragging = false
	track.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local relative = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
			setValue(min + relative * (max - min))
		end
	end)

	self.Library.Flags[flagName] = value

	return {
		Set = function(_, v) setValue(v) end,
		Get = function() return value end,
	}
end

-- Dropdown -------------------------------------------------------
function Groupbox:AddDropdown(flagName, opts, callback)
	opts = opts or {}
	local options = opts.Options or {}
	local selected = opts.Default or options[1]

	local row = New("Frame", {
		Parent = self.Contents,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 33),
	})
	TextLabel({ Parent = row, Size = UDim2.new(1, 0, 0, 18), Text = opts.Text or flagName })

	local button = New("Frame", {
		Parent = row,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 15),
		Position = UDim2.new(0, 0, 0, 18),
	})
	AddBevel(button, Theme.Background)
	AddFillGradient(button)

	local text = TextLabel({
		Parent = button,
		Size = UDim2.new(1, -20, 1, 0),
		Position = UDim2.fromOffset(4, 0),
		Text = tostring(selected),
	})
	local arrow = TextLabel({
		Parent = button,
		Size = UDim2.fromOffset(11, 14),
		Position = UDim2.new(1, -14, 0, 0),
		Text = "+",
		TextSize = 9,
	})

	local list = New("Frame", {
		Parent = button,
		BackgroundColor3 = Theme.TitleBar,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 0),
		Position = UDim2.new(0, 0, 1, 2),
		AutomaticSize = Enum.AutomaticSize.Y,
		Visible = false,
		ZIndex = 20,
	})
	AddBevel(list, Theme.Background)
	AddFillGradient(list)
	New("UIListLayout", {
		Parent = list,
		SortOrder = Enum.SortOrder.LayoutOrder,
		Padding = UDim.new(0, 4),
		HorizontalFlex = Enum.UIFlexAlignment.Fill,
	})
	New("UIPadding", {
		Parent = list,
		PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4),
		PaddingLeft = UDim.new(0, 4), PaddingRight = UDim.new(0, 4),
	})

	local function setSelected(value, fire)
		selected = value
		text.Text = tostring(value)
		self.Library.Flags[flagName] = value
		if fire ~= false and callback then callback(value) end
	end

	for _, option in ipairs(options) do
		local optionLabel = TextLabel({
			Parent = list,
			Size = UDim2.new(1, 0, 0, 12),
			ZIndex = 20,
			Text = tostring(option),
			TextColor3 = option == selected and Theme.Accent or Theme.Text,
		})
		Clickable(optionLabel, function()
			for _, child in ipairs(list:GetChildren()) do
				if child:IsA("TextLabel") then
					child.TextColor3 = (child.Text == tostring(option)) and Theme.Accent or Theme.Text
				end
			end
			setSelected(option)
			list.Visible = false
		end)
	end

	Clickable(button, function()
		list.Visible = not list.Visible
	end)

	self.Library.Flags[flagName] = selected

	return {
		Set = function(_, v) setSelected(v) end,
		Get = function() return selected end,
	}
end

-- Keybind -------------------------------------------------------
function Groupbox:AddKeybind(flagName, opts, callback)
	opts = opts or {}
	local mode = opts.Mode or "Toggle" -- "Toggle" | "Hold" | "Always"
	local bind = opts.Default

	local row = New("Frame", {
		Parent = self.Contents,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 12),
	})
	TextLabel({
		Parent = row,
		Size = UDim2.fromOffset(91, 12),
		Text = string.format('%s (<font color="rgb(255, 82, 85)">%s</font>)', opts.Text or flagName, mode:lower()),
	})
	local bindLabel = TextLabel({
		Parent = row,
		Size = UDim2.fromOffset(30, 12),
		Position = UDim2.new(1, -30, 0, 0),
		TextXAlignment = Enum.TextXAlignment.Right,
		TextColor3 = bind and Theme.Accent or Theme.SubText,
		Text = bind and bind.Name or "unbinded",
	})

	local listening = false
	Clickable(bindLabel, function()
		listening = true
		bindLabel.Text = "..."
	end)

	UserInputService.InputBegan:Connect(function(input, processed)
		if processed then return end
		if listening and input.UserInputType == Enum.UserInputType.Keyboard then
			bind = input.KeyCode
			bindLabel.Text = bind.Name
			bindLabel.TextColor3 = Theme.Accent
			listening = false
			self.Library.Flags[flagName] = bind
			return
		end
		if bind and input.KeyCode == bind then
			if mode == "Toggle" or mode == "Hold" then
				if callback then callback(true) end
			end
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if mode == "Hold" and bind and input.KeyCode == bind then
			if callback then callback(false) end
		end
	end)

	self.Library.Flags[flagName] = bind

	return {
		Get = function() return bind end,
	}
end

-- Button -------------------------------------------------------
function Groupbox:AddButton(text, callback, accent)
	local frame = New("Frame", {
		Parent = self.Contents,
		BackgroundColor3 = accent and Theme.Accent or Theme.Background,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 15),
	})
	AddFillGradient(frame)
	AddBevel(frame, accent and Theme.Accent or Theme.StrokeDark)

	local button = New("TextButton", {
		Parent = frame,
		BackgroundTransparency = 1,
		Size = UDim2.fromScale(1, 1),
		FontFace = Theme.Font,
		TextSize = 12,
		TextColor3 = Theme.Text,
		TextStrokeTransparency = 0,
		RichText = true,
		Text = text,
	})

	button.MouseButton1Click:Connect(function()
		if callback then callback() end
	end)

	return button
end

-- Label (static text row) ---------------------------------------
function Groupbox:AddLabel(text)
	return TextLabel({
		Parent = self.Contents,
		Size = UDim2.new(1, 0, 0, 12),
		Text = text,
	})
end

--============================================================
-- WATERMARK (standalone widget, not tied to a window)
--============================================================

function Library:CreateWatermark(config)
	config = config or {}
	local gui = New("ScreenGui", {
		Name = "Watermark",
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		ResetOnSpawn = false,
		Parent = LocalPlayer:WaitForChild("PlayerGui"),
	})

	local frame = New("Frame", {
		Parent = gui,
		BackgroundColor3 = Theme.TitleBar,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(config.Width or 183, 20),
		Position = config.Position or UDim2.fromOffset(10, 10),
	})
	AddFillGradient(frame)
	AddBevel(frame)

	local label = TextLabel({
		Parent = frame,
		Size = UDim2.fromScale(1, 1),
		TextXAlignment = Enum.TextXAlignment.Center,
		Text = config.Text or "",
	})

	New("Frame", {
		Parent = frame,
		BackgroundColor3 = Theme.Accent,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 1),
		Position = UDim2.new(0, 0, 1, -1),
	})

	return {
		SetText = function(_, text) label.Text = text end,
		Destroy = function() gui:Destroy() end,
	}
end

return Library
