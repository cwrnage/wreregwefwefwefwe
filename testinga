-- CONFIG (string-based: GetConfig() / LoadConfig(data)) + THEME + NOTIFICATIONS
--============================================================

local HttpService = game:GetService("HttpService")

local function fileApiAvailable()
	return writefile ~= nil and readfile ~= nil and isfile ~= nil and isfolder ~= nil and makefolder ~= nil and listfiles ~= nil
end

-- Color3/EnumItem values aren't JSON-safe on their own, so we wrap them in a
-- tagged table going out and unwrap on the way back in.
local function SerializeValue(value)
	local kind = typeof(value)
	if kind == "Color3" then
		return { __type = "Color3", R = value.R, G = value.G, B = value.B }
	elseif kind == "EnumItem" then
		return { __type = "Enum", EnumType = tostring(value.EnumType), Name = value.Name }
	elseif kind == "table" then
		local out = {}
		for k, v in pairs(value) do out[k] = SerializeValue(v) end
		return out
	else
		return value
	end
end

local function DeserializeValue(value)
	if typeof(value) == "table" then
		if value.__type == "Color3" then
			return Color3.new(value.R, value.G, value.B)
		elseif value.__type == "Enum" then
			return Enum[value.EnumType][value.Name]
		else
			local out = {}
			for k, v in pairs(value) do out[k] = DeserializeValue(v) end
			return out
		end
	else
		return value
	end
end

-- Returns the current Flags table as a JSON string.
function Window:GetConfig()
	local serialized = {}
	for flag, value in pairs(self.Flags) do
		serialized[flag] = SerializeValue(value)
	end
	local ok, encoded = pcall(HttpService.JSONEncode, HttpService, serialized)
	if ok then return encoded end
	return "{}"
end

-- Accepts a JSON string (e.g. from readfile), applies it to Flags, and
-- pushes each value into its live component if one registered a setter.
function Window:LoadConfig(data)
	local ok, decoded = pcall(HttpService.JSONDecode, HttpService, data)
	if not ok then return false, decoded end
	for flag, raw in pairs(decoded) do
		local value = DeserializeValue(raw)
		self.Flags[flag] = value
		local setter = self._flagSetters[flag]
		if setter then pcall(setter, value) end
	end
	return true
end

-- Live theme switching: updates the shared accent color and re-runs every
-- registered refresher (toggles, sliders, buttons, scrollbars, watermark...).
-- Only affects the color of already-built components; the window Title's
-- accent word is set once at creation and won't retroactively recolor.
function Window:ChangeAccent(color)
	Theme.Accent = color
	for _, refresh in ipairs(AccentRefreshers) do
		pcall(refresh)
	end
end

-- Small toast notification, stacked top-right, auto-dismissed after `duration` seconds.
function Window:Notification(message, duration)
	duration = duration or 3
	if not self._notifyContainer then
		self._notifyContainer = New("Frame", {
			Parent = self.ScreenGui,
			BackgroundTransparency = 1,
			Size = UDim2.new(0, 220, 1, -20),
			Position = UDim2.new(1, -230, 0, 10),
			ZIndex = 60,
		})
		New("UIListLayout", {
			Parent = self._notifyContainer,
			SortOrder = Enum.SortOrder.LayoutOrder,
			Padding = UDim.new(0, 6),
			HorizontalAlignment = Enum.HorizontalAlignment.Right,
		})
	end

	local toast = New("Frame", {
		Parent = self._notifyContainer,
		BackgroundColor3 = Theme.TitleBar,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		ZIndex = 60,
	})
	AddBevel(toast)
	AddFillGradient(toast)
	TextLabel({
		Parent = toast,
		Size = UDim2.new(1, -8, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		Position = UDim2.fromOffset(4, 2),
		TextWrapped = true,
		ZIndex = 60,
		Text = message,
	})
	New("UIPadding", { Parent = toast, PaddingBottom = UDim.new(0, 4) })

	task.delay(duration, function()
		if toast then toast:Destroy() end
	end)
end

-- Adds a Save / Load / Delete / Refresh config UI to a groupbox: a name
-- textbox, a dropdown of existing config names, and the four buttons.
-- Files are written as `<Folder>/<name><Extension>` containing the JSON
-- string from GetConfig(). Silently no-ops if the executor has no file API
-- (e.g. running in Studio).
function Groupbox:AddConfigList(opts)
	opts = opts or {}
	local folder = opts.Folder or "UILibrary/configs"
	local extension = opts.Extension or ".cfg"

	if fileApiAvailable() and not isfolder(folder) then
		pcall(makefolder, folder)
	end

	local function listConfigNames()
		local names = {}
		if fileApiAvailable() and isfolder(folder) then
			pcall(function()
				for _, path in ipairs(listfiles(folder)) do
					local name = path:match("([^/\\]+)$")
					if name and name:sub(-#extension) == extension then
						table.insert(names, name:sub(1, -#extension - 1))
					end
				end
			end)
		end
		if #names == 0 then table.insert(names, "No configs") end
		return names
	end

	self:AddTextbox("config_name_input", { Text = "Config Name", Placeholder = "MyConfig" })

	local configDropdown
	self:AddButton("Save Config", function()
		local name = self.Library.Flags["config_name_input"]
		if not name or name == "" then
			self.Library:Notification("Enter a config name first.", 2)
			return
		end
		if fileApiAvailable() then
			pcall(writefile, folder .. "/" .. name .. extension, self.Library:GetConfig())
		end
		self.Library:Notification("Saved: " .. name, 2)
		configDropdown:Refresh(listConfigNames())
	end)

	configDropdown = self:AddDropdown("config_selected", { Text = "Saved Configs", Options = listConfigNames() })

	self:AddButton("Load Config", function()
		local name = self.Library.Flags["config_selected"]
		if name and name ~= "No configs" and fileApiAvailable() then
			local path = folder .. "/" .. name .. extension
			if isfile(path) then
				self.Library:LoadConfig(readfile(path))
				self.Library:Notification("Loaded: " .. name, 2)
			end
		end
	end)

	self:AddButton("Refresh List", function()
		configDropdown:Refresh(listConfigNames())
	end)

	self:AddButton("Delete Config", function()
		local name = self.Library.Flags["config_selected"]
		if name and name ~= "No configs" and fileApiAvailable() then
			local path = folder .. "/" .. name .. extension
			if isfile(path) then
				pcall(delfile, path)
				configDropdown:Refresh(listConfigNames())
				self.Library:Notification("Deleted: " .. name, 2)
			end
		end
	end)

	return { Refresh = function() configDropdown:Refresh(listConfigNames()) end }
end

--============================================================
-- STANDALONE KEYBINDS PANEL (auto-updating list of all AddKeybind calls)
--============================================================

function Window:CreateKeybindsList(config)
	config = config or {}

	local frame = New("Frame", {
		Parent = self.ScreenGui,
		BackgroundColor3 = Theme.TitleBar,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(config.Width or (self.IsMobile and 130 or 155), 20),
		Position = config.Position or UDim2.fromOffset(200, 50),
	})
	AddFillGradient(frame)
	AddBevel(frame)
	TextLabel({ Parent = frame, Size = UDim2.fromScale(1, 1), TextXAlignment = Enum.TextXAlignment.Center, Text = config.Title or "Keybinds" })
	MakeDraggable(frame, frame)

	local contents = New("Frame", {
		Parent = frame,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 0),
		Position = UDim2.new(0, 0, 1, 1),
		AutomaticSize = Enum.AutomaticSize.Y,
	})
	AddBevel(contents)
	New("UIListLayout", { Parent = contents, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 4), HorizontalFlex = Enum.UIFlexAlignment.Fill })
	New("UIPadding", { Parent = contents, PaddingTop = UDim.new(0, 6), PaddingBottom = UDim.new(0, 6), PaddingLeft = UDim.new(0, 6), PaddingRight = UDim.new(0, 6) })

	local function refresh()
		for _, child in ipairs(contents:GetChildren()) do
			if child:IsA("TextLabel") then child:Destroy() end
		end
		for _, entry in ipairs(self._keybindEntries) do
			local bind = entry.GetBind()
			if bind then
				TextLabel({
					Parent = contents,
					Size = UDim2.new(1, 0, 0, 12),
					TextColor3 = Theme.Accent,
					Text = string.format("[%s] %s [%s]", bind.Name, entry.DisplayText, entry.Mode:lower()),
				})
			end
		end
		local boundCount = 0
		for _, child in ipairs(contents:GetChildren()) do
			if child:IsA("TextLabel") then boundCount = boundCount + 1 end
		end
		frame.Visible = boundCount > 0
	end

	self._refreshKeybindsPanel = refresh
	refresh()

	return { Refresh = refresh, Frame = frame }
end

