--============================================================
-- CONFIG LIST (save/load Flags to a JSON file via executor file API)
--============================================================

local HttpService = game:GetService("HttpService")

local function fileApiAvailable()
	return writefile ~= nil and readfile ~= nil and isfile ~= nil and isfolder ~= nil and makefolder ~= nil and listfiles ~= nil
end

function Library:SaveConfig(name)
	if not fileApiAvailable() then return false, "file API not available" end
	local folder = self.ConfigFolder or "UILibrary/configs"
	if not isfolder(folder) then makefolder(folder) end
	local ok, encoded = pcall(HttpService.JSONEncode, HttpService, self.Flags)
	if not ok then return false, encoded end
	writefile(folder .. "/" .. name .. ".json", encoded)
	return true
end

function Library:LoadConfig(name, applyCallback)
	if not fileApiAvailable() then return false, "file API not available" end
	local folder = self.ConfigFolder or "UILibrary/configs"
	local path = folder .. "/" .. name .. ".json"
	if not isfile(path) then return false, "config does not exist" end
	local ok, decoded = pcall(HttpService.JSONDecode, HttpService, readfile(path))
	if not ok then return false, decoded end
	for flag, value in pairs(decoded) do
		self.Flags[flag] = value
		if applyCallback then applyCallback(flag, value) end
	end
	return true
end

-- Adds a scrollable list of saved config names to a groupbox, each with
-- Load / Save buttons. Silently does nothing if the executor has no
-- file API (e.g. running in Studio).
function Groupbox:AddConfigList(opts)
	opts = opts or {}
	local folder = opts.Folder or "UILibrary/configs"
	self.Library.ConfigFolder = folder

	local list = New("ScrollingFrame", {
		Parent = self.Contents,
		Active = true,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, opts.Height or 70),
		ScrollBarThickness = 2,
		ScrollBarImageColor3 = Theme.Accent,
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		CanvasSize = UDim2.new(0, 0, 0, 0),
	})
	AddBevel(list)
	New("UIListLayout", { Parent = list, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 4), HorizontalFlex = Enum.UIFlexAlignment.Fill })
	New("UIPadding", { Parent = list, PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4), PaddingLeft = UDim.new(0, 4), PaddingRight = UDim.new(0, 4) })

	local function refresh()
		for _, child in ipairs(list:GetChildren()) do
			if child:IsA("TextLabel") then child:Destroy() end
		end
		if not fileApiAvailable() or not isfolder(folder) then return end
		for _, path in ipairs(listfiles(folder)) do
			local name = path:match("([^/\\]+)%.json$")
			if name then
				local row = TextLabel({ Parent = list, Size = UDim2.new(1, 0, 0, 12), Text = name, TextColor3 = Theme.Accent })
				Clickable(row, function()
					self.Library:LoadConfig(name)
				end)
			end
		end
	end

	local nameBox = New("TextBox", {
		Parent = self.Contents,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 15),
		FontFace = Theme.Font,
		TextSize = 12,
		TextColor3 = Theme.Text,
		PlaceholderText = "config name...",
		Text = "",
		ClearTextOnFocus = false,
	})
	AddBevel(nameBox)

	self:AddButton("Save Config", function()
		if nameBox.Text ~= "" then
			self.Library:SaveConfig(nameBox.Text)
			refresh()
		end
	end)

	refresh()
	return { Refresh = refresh }
end

--============================================================
-- STANDALONE KEYBINDS PANEL (auto-updating list of all AddKeybind calls)
--============================================================

function Window:CreateKeybindsList(config)
	config = config or {}

	local frame = New("Frame", {
		Parent = self.ScreenGui,
		BackgroundColor3 = Theme.TitleBar,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(config.Width or (self.IsMobile and 130 or 155), 20),
		Position = config.Position or UDim2.fromOffset(200, 50),
	})
	AddFillGradient(frame)
	AddBevel(frame)
	TextLabel({ Parent = frame, Size = UDim2.fromScale(1, 1), TextXAlignment = Enum.TextXAlignment.Center, Text = config.Title or "Keybinds" })
	MakeDraggable(frame, frame)

	local contents = New("Frame", {
		Parent = frame,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 0),
		Position = UDim2.new(0, 0, 1, 1),
		AutomaticSize = Enum.AutomaticSize.Y,
	})
	AddBevel(contents)
	New("UIListLayout", { Parent = contents, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 4), HorizontalFlex = Enum.UIFlexAlignment.Fill })
	New("UIPadding", { Parent = contents, PaddingTop = UDim.new(0, 6), PaddingBottom = UDim.new(0, 6), PaddingLeft = UDim.new(0, 6), PaddingRight = UDim.new(0, 6) })

	local function refresh()
		for _, child in ipairs(contents:GetChildren()) do
			if child:IsA("TextLabel") then child:Destroy() end
		end
		for _, entry in ipairs(self._keybindEntries) do
			local bind = entry.GetBind()
			if bind then
				TextLabel({
					Parent = contents,
					Size = UDim2.new(1, 0, 0, 12),
					TextColor3 = Theme.Accent,
					Text = string.format("[%s] %s [%s]", bind.Name, entry.DisplayText, entry.Mode:lower()),
				})
			end
		end
		local boundCount = 0
		for _, child in ipairs(contents:GetChildren()) do
			if child:IsA("TextLabel") then boundCount = boundCount + 1 end
		end
		frame.Visible = boundCount > 0
	end

	self._refreshKeybindsPanel = refresh
	refresh()

	return { Refresh = refresh, Frame = frame }
end

return Library
