--============================================================
-- COLOR PICKER (full popup: hue strip + saturation/value box + alpha)
--============================================================

function Groupbox:AddColorPicker(flagName, opts, callback)
	opts = opts or {}
	local hue, sat, val = Color3.toHSV(opts.Default or Color3.fromRGB(255, 161, 45))
	local alpha = opts.Alpha ~= false and (opts.DefaultAlpha or 1) or nil

	local row = New("Frame", {
		Parent = self.Contents,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 12),
	})
	TextLabel({ Parent = row, Size = UDim2.new(1, -40, 1, 0), Text = opts.Text or flagName })

	local swatch = New("Frame", {
		Parent = row,
		BackgroundColor3 = Color3.fromHSV(hue, sat, val),
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(30, 10),
		Position = UDim2.new(1, -30, 0.5, -5),
	})
	AddFillGradient(swatch)
	AddBevel(swatch, Color3.fromHSV(hue, sat, val))

	-- floating popup, parented to the window's ScreenGui so it renders above everything
	local isMobile = self.Library.IsMobile
	local popupW = isMobile and 150 or 175
	local svW, svH = isMobile and 112 or 132, isMobile and 100 or 118
	local popup = New("Frame", {
		Parent = self.Library.ScreenGui,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(popupW, (alpha and 178 or 160) - (isMobile and 18 or 0)),
		Visible = false,
		ZIndex = 50,
	})
	AddFillGradient(popup)
	AddBevel(popup)

	local titleBar = New("Frame", {
		Parent = popup,
		BackgroundColor3 = Theme.TitleBar,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 20),
		ZIndex = 50,
	})
	AddFillGradient(titleBar)
	AddBevel(titleBar)
	TextLabel({ Parent = titleBar, Size = UDim2.fromScale(1, 1), TextXAlignment = Enum.TextXAlignment.Center, ZIndex = 50, Text = "Color Picker" })
	MakeDraggable(titleBar, popup)

	-- saturation/value box
	local svBox = New("Frame", {
		Parent = popup,
		BackgroundColor3 = Color3.fromHSV(hue, 1, 1),
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(svW, svH),
		Position = UDim2.fromOffset(10, 30),
		ZIndex = 50,
	})
	AddBevel(svBox)
	local satOverlay = New("Frame", { Parent = svBox, BackgroundColor3 = Color3.new(1, 1, 1), BorderSizePixel = 0, Size = UDim2.fromScale(1, 1), ZIndex = 51 })
	New("UIGradient", { Parent = satOverlay, Transparency = NumberSequence.new({ NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(1, 1) }) })
	local valOverlay = New("Frame", { Parent = svBox, BackgroundColor3 = Color3.new(0, 0, 0), BorderSizePixel = 0, Size = UDim2.fromScale(1, 1), ZIndex = 52 })
	New("UIGradient", { Parent = valOverlay, Rotation = 90, Transparency = NumberSequence.new({ NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(1, 0) }) })
	local svCursor = New("Frame", {
		Parent = svBox,
		BackgroundColor3 = Color3.new(1, 1, 1),
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(6, 6),
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.fromScale(sat, 1 - val),
		ZIndex = 53,
	})
	New("UICorner", { Parent = svCursor, CornerRadius = UDim.new(1, 0) })
	New("UIStroke", { Parent = svCursor, Color = Color3.new(0, 0, 0), Thickness = 1 })

	-- hue strip
	local hueBar = New("Frame", {
		Parent = popup,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(12, svH + 1),
		Position = UDim2.fromOffset(10 + svW + 11, 29),
		ZIndex = 50,
	})
	New("UIGradient", {
		Parent = hueBar,
		Rotation = 90,
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
			ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255, 255, 0)),
			ColorSequenceKeypoint.new(0.30, Color3.fromRGB(0, 255, 0)),
			ColorSequenceKeypoint.new(0.47, Color3.fromRGB(0, 255, 255)),
			ColorSequenceKeypoint.new(0.61, Color3.fromRGB(0, 0, 255)),
			ColorSequenceKeypoint.new(0.76, Color3.fromRGB(255, 0, 255)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0)),
		}),
	})
	AddBevel(hueBar)
	local hueCursor = New("Frame", {
		Parent = hueBar, BackgroundColor3 = Color3.new(1, 1, 1), BorderSizePixel = 0,
		Size = UDim2.new(1, 4, 0, 2), AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new(0.5, 0, hue, 0), ZIndex = 51,
	})
	New("UIStroke", { Parent = hueCursor, Color = Color3.new(0, 0, 0), Thickness = 1 })

	local alphaBar, alphaCursor
	if alpha then
		alphaBar = New("Frame", {
			Parent = popup, BackgroundColor3 = Color3.new(1, 1, 1), BorderSizePixel = 0,
			Size = UDim2.fromOffset(popupW - 20, 12), Position = UDim2.fromOffset(10, 30 + svH + 6), ZIndex = 50,
		})
		AddBevel(alphaBar)
		New("UIGradient", { Parent = alphaBar, Color = ColorSequence.new(Color3.new(0, 0, 0), Color3.new(1, 1, 1)) })
		alphaCursor = New("Frame", {
			Parent = alphaBar, BackgroundColor3 = Color3.new(1, 1, 1), BorderSizePixel = 0,
			Size = UDim2.new(0, 2, 1, 4), AnchorPoint = Vector2.new(0.5, 0.5),
			Position = UDim2.new(alpha, 0, 0.5, 0), ZIndex = 51,
		})
		New("UIStroke", { Parent = alphaCursor, Color = Color3.new(0, 0, 0), Thickness = 1 })
	end

	local function currentColor()
		return Color3.fromHSV(hue, sat, val)
	end

	local function fire()
		local color = currentColor()
		swatch.BackgroundColor3 = color
		self.Library.Flags[flagName] = alpha and { Color = color, Alpha = alpha } or color
		if callback then callback(color, alpha) end
	end

	local function updateSV(inputPos)
		local relX = math.clamp((inputPos.X - svBox.AbsolutePosition.X) / svBox.AbsoluteSize.X, 0, 1)
		local relY = math.clamp((inputPos.Y - svBox.AbsolutePosition.Y) / svBox.AbsoluteSize.Y, 0, 1)
		sat, val = relX, 1 - relY
		svCursor.Position = UDim2.fromScale(sat, 1 - val)
		fire()
	end

	local function updateHue(inputPos)
		local rel = math.clamp((inputPos.Y - hueBar.AbsolutePosition.Y) / hueBar.AbsoluteSize.Y, 0, 1)
		hue = rel
		hueCursor.Position = UDim2.new(0.5, 0, hue, 0)
		svBox.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
		fire()
	end

	local function updateAlpha(inputPos)
		local rel = math.clamp((inputPos.X - alphaBar.AbsolutePosition.X) / alphaBar.AbsoluteSize.X, 0, 1)
		alpha = rel
		alphaCursor.Position = UDim2.new(alpha, 0, 0.5, 0)
		fire()
	end

	local draggingSV, draggingHue, draggingAlpha = false, false, false
	svBox.InputBegan:Connect(function(input)
		if IsPressInput(input.UserInputType) then draggingSV = true; updateSV(input.Position) end
	end)
	hueBar.InputBegan:Connect(function(input)
		if IsPressInput(input.UserInputType) then draggingHue = true; updateHue(input.Position) end
	end)
	if alphaBar then
		alphaBar.InputBegan:Connect(function(input)
			if IsPressInput(input.UserInputType) then draggingAlpha = true; updateAlpha(input.Position) end
		end)
	end
	UserInputService.InputEnded:Connect(function(input)
		if IsPressInput(input.UserInputType) then
			draggingSV, draggingHue, draggingAlpha = false, false, false
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if not IsMoveInput(input.UserInputType) then return end
		if draggingSV then updateSV(input.Position) end
		if draggingHue then updateHue(input.Position) end
		if draggingAlpha then updateAlpha(input.Position) end
	end)

	Clickable(swatch, function()
		if not popup.Visible then
			popup.Position = UDim2.fromOffset(swatch.AbsolutePosition.X - popupW + 30, swatch.AbsolutePosition.Y)
		end
		popup.Visible = not popup.Visible
	end)

	-- Clicking/tapping anywhere outside the popup (and outside the swatch,
	-- which has its own toggle above) finalizes the color and closes it.
	UserInputService.InputBegan:Connect(function(input)
		if not popup.Visible then return end
		if not IsPressInput(input.UserInputType) then return end
		if PointInside(popup, input.Position) or PointInside(swatch, input.Position) then return end
		popup.Visible = false
	end)

	self.Library.Flags[flagName] = alpha and { Color = currentColor(), Alpha = alpha } or currentColor()

	local function applyColor(color, a)
		hue, sat, val = Color3.toHSV(color)
		if a then alpha = a end
		svBox.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
		svCursor.Position = UDim2.fromScale(sat, 1 - val)
		hueCursor.Position = UDim2.new(0.5, 0, hue, 0)
		if alphaCursor then alphaCursor.Position = UDim2.new(alpha, 0, 0.5, 0) end
		fire()
	end

	-- Single-argument form for the flag-setter registry (LoadConfig calls
	-- setters with just the deserialized value, which may be a plain Color3
	-- or the {Color, Alpha} shape this component stores in Flags).
	self.Library._flagSetters[flagName] = function(value)
		if typeof(value) == "table" then
			applyColor(value.Color, value.Alpha)
		else
			applyColor(value)
		end
	end

	return {
		Set = function(_, color, a) applyColor(color, a) end,
		Get = function() return currentColor(), alpha end,
	}
end

