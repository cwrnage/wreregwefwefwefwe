--[[
	UILibrary.lua

	A clean, component-based rewrite of the raw Instance.new dump.
	Same visual language (dark background, red accent, tahoma-xp font,
	1px strokes + subtle gradients) but built as reusable factories
	instead of one-off instances, so adding a new toggle/slider/etc.
	is one function call instead of 20+ lines of boilerplate.

	Usage:
		local UI = require(script.UILibrary)
		local Window = UI:CreateWindow({ Title = "serial.xyz" })

		local Tab1 = Window:CreateTab("Aimbot")
		local Left = Tab1:CreateGroupbox("Left", "example section 1")

		Left:AddToggle("MyToggle", { Text = "example toggle", Default = false }, function(state)
			print("toggle ->", state)
		end)

		Left:AddSlider("MySlider", { Text = "example slider", Min = 0, Max = 100, Default = 82, Suffix = "%" }, function(value)
			print("slider ->", value)
		end)
]]

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer

--============================================================
-- THEME
--============================================================

local Theme = {
	Background   = Color3.fromRGB(28, 28, 28),
	Section      = Color3.fromRGB(43, 43, 43),
	TitleBar     = Color3.fromRGB(51, 51, 51),
	Accent       = Color3.fromRGB(255, 83, 86),
	StrokeDark   = Color3.fromRGB(51, 51, 51),
	StrokeLight  = Color3.fromRGB(255, 255, 255),
	Text         = Color3.fromRGB(255, 255, 255),
	SubText      = Color3.fromRGB(209, 209, 209),
	MutedText    = Color3.fromRGB(131, 131, 131),
	Font         = Font.new("rbxasset://fonts/families/windows-xp-tahoma.json"),
}

--============================================================
-- LOW LEVEL HELPERS
--============================================================

-- Instance.new + property table + children, in one call.
local function New(className, props, children)
	local inst = Instance.new(className)
	for prop, value in pairs(props or {}) do
		inst[prop] = value
	end
	for _, child in ipairs(children or {}) do
		child.Parent = inst
	end
	return inst
end

-- Adds the "bright top-left, dark bottom-right" bevel look used everywhere
-- in the original dump (outer 1px black stroke + inner light/dark stroke
-- with a subtle vertical gradient).
local function AddBevel(parent, innerColor)
	New("UIStroke", { Parent = parent, ApplyStrokeMode = Enum.ApplyStrokeMode.Border })
	local inner = New("UIStroke", {
		Parent = parent,
		Color = innerColor or Theme.StrokeDark,
		ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
		BorderStrokePosition = Enum.BorderStrokePosition.Inner,
	})
	New("UIGradient", {
		Parent = inner,
		Rotation = 90,
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(159, 159, 159)),
			ColorSequenceKeypoint.new(0.05, Color3.fromRGB(241, 241, 241)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255)),
		}),
	})
end

local function AddFillGradient(parent)
	New("UIGradient", {
		Parent = parent,
		Rotation = 90,
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(173, 173, 173)),
		}),
	})
end

local function Label(props)
	return New("TextLabel", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		FontFace = Theme.Font,
		TextSize = 12,
		TextColor3 = Theme.Text,
		TextStrokeTransparency = 0.5,
		TextXAlignment = Enum.TextXAlignment.Left,
		RichText = true,
		Text = "",
	}, nil), props and (function(l)
		for k, v in pairs(props) do l[k] = v end
		return l
	end)
end

-- simpler helper: creates a TextLabel with props merged in directly
local function TextLabel(props)
	local base = {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		FontFace = Theme.Font,
		TextSize = 12,
		TextColor3 = Theme.Text,
		TextStrokeTransparency = 0.5,
		TextXAlignment = Enum.TextXAlignment.Left,
		RichText = true,
	}
	for k, v in pairs(props or {}) do base[k] = v end
	return New("TextLabel", base)
end

local function Clickable(parent, callback)
	local button = New("TextButton", {
		Parent = parent,
		BackgroundTransparency = 1,
		Text = "",
		Size = UDim2.fromScale(1, 1),
		ZIndex = 10,
	})
	button.MouseButton1Click:Connect(function()
		if callback then callback() end
	end)
	return button
end

--============================================================
-- LIBRARY / WINDOW
--============================================================

local Library = {}
Library.__index = Library

local Window = {}
Window.__index = Window

local Tab = {}
Tab.__index = Tab

local Groupbox = {}
Groupbox.__index = Groupbox

function Library:CreateWindow(config)
	config = config or {}

	local self = setmetatable({}, Library)
	self.Flags = {} -- Flags[name] = current value, shared across all components

	self.ScreenGui = New("ScreenGui", {
		Name = config.Title or "UILibrary",
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		ResetOnSpawn = false,
		Parent = LocalPlayer:WaitForChild("PlayerGui"),
	})

	self.Main = New("Frame", {
		Name = "Main",
		Parent = self.ScreenGui,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Size = config.Size or UDim2.fromOffset(450, 500),
		Position = config.Position or UDim2.fromScale(0.36, 0.15),
	})
	AddBevel(self.Main)
	New("UIShadow", { Parent = self.Main })

	-- title strip
	local titleBar = New("Frame", {
		Parent = self.Main,
		BackgroundColor3 = Color3.new(1, 1, 1),
		BorderSizePixel = 0,
		Size = UDim2.new(1, 2, 0, 18),
		Position = UDim2.new(0, -1, 0, -18),
	})
	New("UIGradient", {
		Parent = titleBar,
		Rotation = 90,
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(31, 31, 31)),
			ColorSequenceKeypoint.new(0.875, Theme.Accent),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(31, 31, 31)),
		}),
	})
	TextLabel({
		Parent = titleBar,
		Size = UDim2.fromScale(1, 1),
		BackgroundColor3 = Color3.new(1, 1, 1),
		BackgroundTransparency = 1,
		Text = config.Title or "UI Library",
	})

	-- Holder = outer rounded frame, Container = tabs + content area
	self.Holder = New("Frame", {
		Parent = self.Main,
		BackgroundColor3 = Theme.Section,
		BorderSizePixel = 0,
		Size = UDim2.new(1, -24, 1, -22),
		Position = UDim2.new(0, 12, 0, 10),
	})
	AddBevel(self.Holder)

	self.TabsBar = New("Frame", {
		Parent = self.Holder,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -12, 0, 20),
		Position = UDim2.new(0, 6, 0, 6),
	})
	New("UIListLayout", {
		Parent = self.TabsBar,
		FillDirection = Enum.FillDirection.Horizontal,
		SortOrder = Enum.SortOrder.LayoutOrder,
		Padding = UDim.new(0, 5),
		HorizontalFlex = Enum.UIFlexAlignment.Fill,
	})

	self.Container = New("Frame", {
		Parent = self.Holder,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Size = UDim2.new(1, -12, 1, -32),
		Position = UDim2.new(0, 6, 0, 30),
	})
	AddBevel(self.Container)
	New("UIListLayout", {
		Parent = self.Container,
		FillDirection = Enum.FillDirection.Horizontal,
		HorizontalFlex = Enum.UIFlexAlignment.Fill,
		VerticalFlex = Enum.UIFlexAlignment.Fill,
		Padding = UDim.new(0, 5),
		SortOrder = Enum.SortOrder.LayoutOrder,
	})

	self.Tabs = {}
	self._firstTab = true

	return self
end

function Window:CreateTab(name)
	local tabButton = New("Frame", {
		Parent = self.TabsBar,
		BackgroundColor3 = Color3.new(1, 1, 1),
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(100, 20),
		LayoutOrder = #self.Tabs,
	})
	New("UIGradient", {
		Parent = tabButton,
		Rotation = 90,
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Theme.TitleBar),
			ColorSequenceKeypoint.new(0.75, Color3.fromRGB(31, 31, 31)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(30, 30, 30)),
		}),
	})
	local label = TextLabel({
		Parent = tabButton,
		Size = UDim2.fromScale(1, 1),
		TextXAlignment = Enum.TextXAlignment.Center,
		Text = name,
		TextColor3 = self._firstTab and Theme.Text or Theme.MutedText,
	})

	local page = New("Frame", {
		Parent = self.Container,
		BackgroundTransparency = 1,
		Size = UDim2.fromScale(1, 1),
		Visible = self._firstTab,
	})
	New("UIListLayout", {
		Parent = page,
		FillDirection = Enum.FillDirection.Horizontal,
		HorizontalFlex = Enum.UIFlexAlignment.Fill,
		Padding = UDim.new(0, 8),
		SortOrder = Enum.SortOrder.LayoutOrder,
	})

	local tab = setmetatable({
		Name = name,
		Page = page,
		Button = tabButton,
		Label = label,
		Library = self,
		_columns = {},
	}, Tab)

	Clickable(tabButton, function()
		for _, t in ipairs(self.Tabs) do
			t.Page.Visible = false
			t.Label.TextColor3 = Theme.MutedText
		end
		page.Visible = true
		label.TextColor3 = Theme.Text
	end)

	self._firstTab = false
	table.insert(self.Tabs, tab)
	return tab
end

-- side: "Left" (default) or "Right" -- controls which column the groupbox
-- stacks into, matching the original two-column layout.
function Tab:CreateGroupbox(side, title)
	side = side or "Left"

	local column = self._columns[side]
	if not column then
		column = New("ScrollingFrame", {
			Parent = self.Page,
			Name = side,
			Active = true,
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Size = UDim2.fromOffset(100, 100), -- resized by UIListLayout fill
			ScrollBarThickness = 0,
			CanvasSize = UDim2.new(0, 0, 0, 0),
			AutomaticCanvasSize = Enum.AutomaticSize.Y,
		})
		New("UIListLayout", {
			Parent = column,
			SortOrder = Enum.SortOrder.LayoutOrder,
			Padding = UDim.new(0, 8),
			HorizontalFlex = Enum.UIFlexAlignment.Fill,
		})
		New("UIPadding", {
			Parent = column,
			PaddingTop = UDim.new(0, 6),
			PaddingBottom = UDim.new(0, 6),
			PaddingLeft = UDim.new(0, 6),
			PaddingRight = UDim.new(0, 6),
		})
		self._columns[side] = column
	end

	local box = New("Frame", {
		Parent = column,
		BackgroundColor3 = Color3.new(1, 1, 1),
		BackgroundTransparency = 0.9,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
	})
	AddBevel(box)

	local titleBar = New("Frame", {
		Parent = box,
		BackgroundColor3 = Theme.TitleBar,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 20),
	})
	AddFillGradient(titleBar)
	AddBevel(titleBar)
	TextLabel({
		Parent = titleBar,
		Size = UDim2.new(1, -6, 1, 0),
		Position = UDim2.fromOffset(6, 0),
		Text = title,
	})

	local contents = New("Frame", {
		Parent = titleBar,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 0),
		Position = UDim2.new(0, 0, 1, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
	})
	New("UIListLayout", {
		Parent = contents,
		SortOrder = Enum.SortOrder.LayoutOrder,
		Padding = UDim.new(0, 4),
		HorizontalFlex = Enum.UIFlexAlignment.Fill,
	})
	New("UIPadding", {
		Parent = contents,
		PaddingTop = UDim.new(0, 6),
		PaddingBottom = UDim.new(0, 6),
		PaddingLeft = UDim.new(0, 6),
		PaddingRight = UDim.new(0, 6),
	})
	AddBevel(contents)

	return setmetatable({
		Contents = contents,
		Library = self.Library,
	}, Groupbox)
end

