local function BuildTitleText(config)
	local title = config.Title or "UI Library"
	local text = title
	if config.TitleAccent then
		local startIdx, endIdx = title:find(config.TitleAccent, 1, true)
		if startIdx then
			local accentColor = string.format("rgb(%d, %d, %d)", Theme.Accent.R * 255, Theme.Accent.G * 255, Theme.Accent.B * 255)
			text = title:sub(1, startIdx - 1)
				.. string.format('<font color="%s">%s</font>', accentColor, title:sub(startIdx, endIdx))
				.. title:sub(endIdx + 1)
		end
	end
	if config.Subtitle then
		text = text .. " ~ " .. config.Subtitle
	end
	return text
end

function Library:CreateWindow(config)
	config = config or {}

	local self = setmetatable({}, Window)
	self.Flags = {} -- Flags[name] = current value, shared across all components
	self.Configs = {} -- populated by CreateConfigList
	self._keybindEntries = {} -- populated by AddKeybind, read by CreateKeybindsList
	self._flagSetters = {} -- FlagSetters[name] = function(value) -- lets LoadConfig push values into the live UI

	self.ScreenGui = New("ScreenGui", {
		Name = config.Title or "UILibrary",
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		ResetOnSpawn = false,
		Parent = LocalPlayer:WaitForChild("PlayerGui"),
	})
	ParentAboveCoreUI(self.ScreenGui)

	self.IsMobile = IsMobile
	local defaultSize = IsMobile and UDim2.fromOffset(320, 400) or UDim2.fromOffset(450, 500)
	local defaultPosition = IsMobile and UDim2.new(0.5, -160, 0.5, -200) or UDim2.fromScale(0.36, 0.15)

	self.Main = New("Frame", {
		Name = "Main",
		Parent = self.ScreenGui,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Size = config.Size or defaultSize,
		Position = config.Position or defaultPosition,
	})
	AddBevel(self.Main)
	New("UIShadow", { Parent = self.Main })

	-- title strip
	local titleBar = New("Frame", {
		Parent = self.Main,
		BackgroundColor3 = Color3.new(1, 1, 1),
		BorderSizePixel = 0,
		Size = UDim2.new(1, 2, 0, 18),
		Position = UDim2.new(0, -1, 0, -18),
	})
	New("UIGradient", {
		Parent = titleBar,
		Rotation = 90,
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(31, 31, 31)),
			ColorSequenceKeypoint.new(0.875, Theme.Accent),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(31, 31, 31)),
		}),
	})
	TextLabel({
		Parent = titleBar,
		Size = UDim2.fromScale(1, 1),
		BackgroundColor3 = Color3.new(1, 1, 1),
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Center,
		Text = BuildTitleText(config),
	})
	MakeDraggable(titleBar, self.Main)

	-- Holder = outer rounded frame, Container = tabs + content area
	self.Holder = New("Frame", {
		Parent = self.Main,
		BackgroundColor3 = Theme.Section,
		BorderSizePixel = 0,
		Size = UDim2.new(1, -24, 1, -22),
		Position = UDim2.new(0, 12, 0, 10),
	})
	AddBevel(self.Holder)

	self.TabsBar = New("Frame", {
		Parent = self.Holder,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -12, 0, 20),
		Position = UDim2.new(0, 6, 0, 6),
	})
	New("UIListLayout", {
		Parent = self.TabsBar,
		FillDirection = Enum.FillDirection.Horizontal,
		SortOrder = Enum.SortOrder.LayoutOrder,
		Padding = UDim.new(0, 5),
		HorizontalFlex = Enum.UIFlexAlignment.Fill,
	})

	self.Container = New("Frame", {
		Parent = self.Holder,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Size = UDim2.new(1, -12, 1, -32),
		Position = UDim2.new(0, 6, 0, 30),
	})
	AddBevel(self.Container)
	New("UIListLayout", {
		Parent = self.Container,
		FillDirection = Enum.FillDirection.Horizontal,
		HorizontalFlex = Enum.UIFlexAlignment.Fill,
		VerticalFlex = Enum.UIFlexAlignment.Fill,
		Padding = UDim.new(0, 5),
		SortOrder = Enum.SortOrder.LayoutOrder,
	})

	self.Tabs = {}
	self._firstTab = true

	return self
end

function Window:CreateTab(name)
	local tabButton = New("Frame", {
		Parent = self.TabsBar,
		BackgroundColor3 = Color3.new(1, 1, 1),
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(100, 20),
		LayoutOrder = #self.Tabs,
	})
	New("UIStroke", { Parent = tabButton, ApplyStrokeMode = Enum.ApplyStrokeMode.Border }) -- plain outer border
	New("UIGradient", {
		Parent = tabButton,
		Rotation = 90,
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Theme.TitleBar),
			ColorSequenceKeypoint.new(0.747, Color3.fromRGB(31, 31, 31)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(30, 30, 30)),
		}),
	})
	local innerStroke = New("UIStroke", {
		Parent = tabButton,
		ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
		BorderStrokePosition = Enum.BorderStrokePosition.Inner,
	})
	local innerStrokeGradient -- only present while unselected

	local label = TextLabel({
		Parent = tabButton,
		Size = UDim2.fromScale(1, 1),
		TextXAlignment = Enum.TextXAlignment.Center,
		Text = name,
	})

	-- Dark bar under the active tab that visually merges it into the content
	-- area below, plus two tiny corner accents -- all hidden unless selected.
	local connector = New("Frame", {
		Parent = tabButton,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Size = UDim2.new(1, -2, 0, 3),
		Position = UDim2.new(0, 1, 1, -1),
		Visible = false,
	})
	local cornerL = New("Frame", {
		Parent = tabButton,
		BackgroundColor3 = Theme.TitleBar,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(1, 1),
		Position = UDim2.new(0, 0, 1.1, -2),
		Visible = false,
	})
	local cornerR = New("Frame", {
		Parent = tabButton,
		BackgroundColor3 = Theme.TitleBar,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(1, 7),
		Position = UDim2.new(1, -1, 1.284, -11),
		Visible = false,
	})

	local function setSelected(selected)
		label.TextColor3 = selected and Theme.Text or Theme.MutedText
		connector.Visible = selected
		cornerL.Visible = selected
		cornerR.Visible = selected
		if selected then
			innerStroke.Color = Theme.TitleBar
			if innerStrokeGradient then innerStrokeGradient:Destroy(); innerStrokeGradient = nil end
		else
			innerStroke.Color = Color3.fromRGB(212, 212, 212)
			if not innerStrokeGradient then
				innerStrokeGradient = New("UIGradient", {
					Parent = innerStroke,
					Rotation = 90,
					Color = ColorSequence.new({
						ColorSequenceKeypoint.new(0, Color3.fromRGB(90, 90, 90)),
						ColorSequenceKeypoint.new(1, Color3.fromRGB(25, 25, 25)),
					}),
				})
			end
		end
	end
	setSelected(self._firstTab)

	local page = New("Frame", {
		Parent = self.Container,
		BackgroundTransparency = 1,
		Size = UDim2.fromScale(1, 1),
		Visible = self._firstTab,
	})
	New("UIListLayout", {
		Parent = page,
		FillDirection = Enum.FillDirection.Horizontal,
		HorizontalFlex = Enum.UIFlexAlignment.Fill,
		VerticalFlex = Enum.UIFlexAlignment.Fill,
		Padding = UDim.new(0, 8),
		SortOrder = Enum.SortOrder.LayoutOrder,
	})

	local tab = setmetatable({
		Name = name,
		Page = page,
		Button = tabButton,
		Label = label,
		Library = self,
		_columns = {},
		_setSelected = setSelected,
	}, Tab)

	Clickable(tabButton, function()
		for _, t in ipairs(self.Tabs) do
			t.Page.Visible = false
			t._setSelected(false)
		end
		page.Visible = true
		setSelected(true)
	end)

	self._firstTab = false
	table.insert(self.Tabs, tab)
	return tab
end

-- side: "Left" (default) or "Right" -- controls which column the groupbox
-- stacks into, matching the original two-column layout.
function Tab:CreateGroupbox(side, title)
	side = side or "Left"

	local column = self._columns[side]
	if not column then
		column = New("ScrollingFrame", {
			Parent = self.Page,
			Name = side,
			Active = true,
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Size = UDim2.fromOffset(100, 100), -- resized by UIListLayout fill
			ScrollBarThickness = 2,
			ScrollBarImageColor3 = Theme.Accent,
			CanvasSize = UDim2.new(0, 0, 0, 0),
			AutomaticCanvasSize = Enum.AutomaticSize.Y,
		})
		New("UIListLayout", {
			Parent = column,
			SortOrder = Enum.SortOrder.LayoutOrder,
			Padding = UDim.new(0, 8),
			HorizontalFlex = Enum.UIFlexAlignment.Fill,
		})
		New("UIPadding", {
			Parent = column,
			PaddingTop = UDim.new(0, 6),
			PaddingBottom = UDim.new(0, 6),
			PaddingLeft = UDim.new(0, 6),
			PaddingRight = UDim.new(0, 6),
		})
		self._columns[side] = column
		table.insert(AccentRefreshers, function()
			column.ScrollBarImageColor3 = Theme.Accent
		end)
	end

	local box = New("Frame", {
		Parent = column,
		BackgroundColor3 = Color3.new(1, 1, 1),
		BackgroundTransparency = 0.9,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
	})
	AddBevel(box)

	local titleBar = New("Frame", {
		Parent = box,
		BackgroundColor3 = Theme.TitleBar,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 20),
	})
	AddFillGradient(titleBar)
	AddBevel(titleBar)
	TextLabel({
		Parent = titleBar,
		Size = UDim2.new(1, -6, 1, 0),
		Position = UDim2.fromOffset(6, 0),
		Text = title,
	})

	local contents = New("Frame", {
		Parent = box,
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 0),
		Position = UDim2.new(0, 0, 0, 20),
		AutomaticSize = Enum.AutomaticSize.Y,
	})
	New("UIListLayout", {
		Parent = contents,
		SortOrder = Enum.SortOrder.LayoutOrder,
		Padding = UDim.new(0, 4),
		HorizontalFlex = Enum.UIFlexAlignment.Fill,
	})
	New("UIPadding", {
		Parent = contents,
		PaddingTop = UDim.new(0, 6),
		PaddingBottom = UDim.new(0, 6),
		PaddingLeft = UDim.new(0, 6),
		PaddingRight = UDim.new(0, 6),
	})
	AddBevel(contents)

	return setmetatable({
		Contents = contents,
		Library = self.Library,
	}, Groupbox)
end

